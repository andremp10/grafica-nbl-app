# NBL ETL environment template
# Copy to .env and fill real values.
# Never commit .env with credentials.

# MySQL local (Docker)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=nblgrafica_app

# Supabase destination
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=postgresql://postgres:your_password@db.xxxxxxxx.supabase.co:5432/postgres

# Backup protocol: sftp | ftp | ftps
# Production official source: ftp
BACKUP_PROTOCOL=ftp

# SFTP primary source (used when BACKUP_PROTOCOL=sftp)
BACKUP_SFTP_HOST=49.12.151.235
BACKUP_SFTP_PORT=22
BACKUP_SFTP_USER=root
BACKUP_SFTP_PASSWORD=
BACKUP_SSH_KEY_PATH=
BACKUP_SSH_KEY_B64=

# FTP fallback/source
BACKUP_FTP_HOST=162.241.203.52
BACKUP_FTP_PORT=21
BACKUP_FTP_USER=nblgra65
BACKUP_FTP_PASSWORD=
BACKUP_FTP_REMOTE_DIR=/public_html/.well-known/backup-jet

# Backup file naming and retention
BACKUP_REMOTE_DIR=/var/lib/vz/dump
BACKUP_FILENAME_PREFIX=nblgrafica_app-
BACKUP_EXTENSION=.sql
BACKUP_LOCAL_DIR=./backups
# Número de dias para manter backups locais (0 = sem limpeza)
BACKUP_RETENTION_DAYS=7

# ETL controls
ETL_BATCH_SIZE=200
ETL_VALIDATE_ONLY=0
ETL_ONLY_TABLES=
ETL_RETRIES=6
ETL_RETRY_BASE_SLEEP_S=0.8

# Truncate safety
TRUNCATE_ENABLED=1
TRUNCATE_CONFIRM=NO
TRUNCATE_TABLES_MODE=exec_order
TRUNCATE_TABLES_LIST=

# Docker compose / import
DOCKER_COMPOSE_FILE=docker-compose.yml
SQL_INPUT_DIR=./sql_input
MYSQL_HEALTHCHECK_RETRIES=30
MYSQL_HEALTHCHECK_SLEEP=2

# Logging / misc
LOG_LEVEL=INFO
LOGS_DIR=./logs
TZ=America/Fortaleza

# Backup preflight
# python scripts/probe_backup_source.py --date 2026-04-05
